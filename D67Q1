/*Problem: Print topological ordering of a Directed Acyclic Graph (DAG) using DFS.*/
#include <stdio.h>
#include <stdlib.h>

// Node structure
struct Node {
    int vertex;
    struct Node* next;
};

// Create node
struct Node* createNode(int v) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->vertex = v;
    newNode->next = NULL;
    return newNode;
}

// Stack
int stack[1000], top = -1;

void push(int x) {
    stack[++top] = x;
}

// DFS function
void dfs(int v, int visited[], struct Node* adj[]) {
    visited[v] = 1;

    struct Node* temp = adj[v;
    while (temp != NULL) {
        int neighbor = temp->vertex;

        if (!visited[neighbor]) {
            dfs(neighbor, visited, adj);
        }
        temp = temp->next;
    }

    push(v); // push after visiting neighbors
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    struct Node* adj[n];

    // Initialize adjacency list
    for (int i = 0; i < n; i++) {
        adj[i] = NULL;
    }

    int u, v;

    // Input directed edges
    for (int i = 0; i < m; i++) {
        scanf("%d %d", &u, &v);

        struct Node* newNode = createNode(v);
        newNode->next = adj[u];
        adj[u] = newNode;
    }

    int visited[n];

    for (int i = 0; i < n; i++) {
        visited[i] = 0;
    }

    // Call DFS for all vertices (handles disconnected DAG)
    for (int i = 0; i < n; i++) {
        if (!visited[i]) {
            dfs(i, visited, adj);
        }
    }

    // Print topological order (reverse of stack)
    printf("Topological Order: ");
    while (top != -1) {
        printf("%d ", stack[top--]);
    }

    return 0;
}
