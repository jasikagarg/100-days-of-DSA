/*Problem: Implement Binary Search Iterative - Implement the algorithm.

Input:
- First line: integer n
- Second line: n space-separated integers

Output:
- Print the sorted array or search result

Example:
Input:
5
64 34 25 12 22

Output:
12 22 25 34 64*/
#include <stdio.h>

int main() {
    int n, target;

    scanf("%d", &n);
    int arr[n];

    // Input sorted array
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Target to search
    scanf("%d", &target);

    int left = 0, right = n - 1;

    while(left <= right) {
        int mid = (left + right) / 2;

        if(arr[mid] == target) {
            printf("%d", mid);
            return 0;
        }
        else if(arr[mid] < target) {
            left = mid + 1;
        }
        else {
            right = mid - 1;
        }
    }

    printf("-1"); // not found

    return 0;
}
