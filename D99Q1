/*Problem: Given a target distance and cars’ positions & speeds, compute the number of car fleets reaching the destination.
Sort cars by position in descending order and calculate time to reach target.*/
#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int pos;
    int speed;
} Car;

int cmp(const void *a, const void *b) {
    Car *c1 = (Car *)a;
    Car *c2 = (Car *)b;
    return c2->pos - c1->pos; // descending order
}

int main() {
    int n, target;

    // Input format assumed:
    // n target
    // n positions
    // n speeds

    scanf("%d %d", &n, &target);

    Car cars[n];

    for(int i = 0; i < n; i++) {
        scanf("%d", &cars[i].pos);
    }

    for(int i = 0; i < n; i++) {
        scanf("%d", &cars[i].speed);
    }

    qsort(cars, n, sizeof(Car), cmp);

    int fleets = 0;
    double curr_time = -1;

    for(int i = 0; i < n; i++) {
        double time = (double)(target - cars[i].pos) / cars[i].speed;

        if(time > curr_time) {
            fleets++;
            curr_time = time;
        }
    }

    printf("%d", fleets);

    return 0;
}
