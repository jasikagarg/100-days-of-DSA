/*Problem: Given n real numbers in [0,1), sort using bucket sort algorithm.
Distribute into buckets, sort each, concatenate.*/
#include <stdio.h>
#include <stdlib.h>

#define BUCKETS 10

// Simple insertion sort for buckets
void insertionSort(float arr[], int n) {
    for(int i = 1; i < n; i++) {
        float key = arr[i];
        int j = i - 1;

        while(j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = key;
    }
}

int main() {
    int n;
    scanf("%d", &n);

    float arr[n];

    // Input array
    for(int i = 0; i < n; i++) {
        scanf("%f", &arr[i]);
    }

    // Buckets (each bucket can hold n elements max)
    float buckets[BUCKETS][n];
    int count[BUCKETS];

    // Initialize bucket counts
    for(int i = 0; i < BUCKETS; i++) {
        count[i] = 0;
    }

    // Distribute elements into buckets
    for(int i = 0; i < n; i++) {
        int index = arr[i] * BUCKETS;
        buckets[index][count[index]++] = arr[i];
    }

    // Sort individual buckets
    for(int i = 0; i < BUCKETS; i++) {
        if(count[i] > 0) {
            insertionSort(buckets[i], count[i]);
        }
    }

    // Concatenate buckets
    int k = 0;
    for(int i = 0; i < BUCKETS; i++) {
        for(int j = 0; j < count[i]; j++) {
            arr[k++] = buckets[i][j];
        }
    }

    // Print sorted array
    for(int i = 0; i < n; i++) {
        printf("%.2f ", arr[i]);
    }

    return 0;
}
